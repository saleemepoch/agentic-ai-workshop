# =============================================================================
# Agentic AI Workshop — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys:
#
#     cp .env.example .env
#
# Then start your shell with the values exported, or just let Pydantic Settings
# read .env directly. NEVER commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
# Defaults match docker-compose.yml — change them if you deploy elsewhere.
POSTGRES_USER=workshop
POSTGRES_PASSWORD=workshop
POSTGRES_DB=workshop
DATABASE_URL=postgresql+asyncpg://workshop:workshop@localhost:5432/workshop


# -----------------------------------------------------------------------------
# Anthropic (Claude) — LLM for generation, reranking, judging
# -----------------------------------------------------------------------------
# Get a key at https://console.anthropic.com/settings/keys
# Make sure your key belongs to a workspace with credit. The most common
# setup error is keys from one workspace + credits in another. See ADR-011.
ANTHROPIC_API_KEY=sk-ant-api03-...


# -----------------------------------------------------------------------------
# Voyage AI — Text embeddings for semantic search
# -----------------------------------------------------------------------------
# Get a key at https://dashboard.voyageai.com/
# The free tier is 3 RPM, which is too slow for the agent and RAG demos.
# Add a payment method to unlock standard rate limits — you keep the
# 200M free tokens for voyage-3, you just lose the throttle.
VOYAGE_API_KEY=pa-...


# -----------------------------------------------------------------------------
# Langfuse — Observability, tracing, cost tracking
# -----------------------------------------------------------------------------
# Get keys at https://cloud.langfuse.com/ → Project Settings → API Keys
# The host can stay on the cloud default unless you self-host Langfuse.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
WEB_PORT=3000
